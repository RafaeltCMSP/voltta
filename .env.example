# ───────── Servidor ─────────
PORT=3333
NODE_ENV=development
# URL pública do seu backend (usada para registrar o webhook na Loja Integrada)
PUBLIC_URL=http://localhost:3333

# ───────── Banco / Fila ─────────
DATABASE_URL="postgresql://voltta:voltta@localhost:5432/voltta?schema=public"
REDIS_URL="redis://localhost:6379"

# ───────── Lógica de recuperação ─────────
# Quanto tempo (em minutos) esperar após o pedido não-pago antes de mandar o WhatsApp
RECOVERY_DELAY_MINUTES=45
# Só recuperar pedidos a partir deste ano (foco atual)
RECOVERY_MIN_YEAR=2026

# ───────── Monitor (polling da LI) ─────────
# Enquanto não há webhook nativo, varremos a LI periodicamente atrás de pedidos novos.
MONITOR_ENABLED=true
MONITOR_INTERVAL_SECONDS=60

# ───────── Painel web (/dashboard) ─────────
# Token de acesso ao painel (há dados de cliente). Vazio = aberto. Acesse com ?token=...
DASHBOARD_TOKEN=

# ───────── Loja Integrada ─────────
# Use o mock enquanto a Chave de Aplicação não chega (5-10 dias úteis).
# true  = simula respostas da Loja Integrada (não bate na API real)
# false = usa a API real com as chaves abaixo
LI_USE_MOCK=true
LI_API_BASE_URL=https://api.awsli.com.br/api/v1
# Token "secret" que validamos no header do webhook para garantir que veio mesmo da LI
LI_WEBHOOK_SECRET=troque-este-segredo

# ───────── Loja padrão (config por env — usada no deploy) ─────────
# Se LI_API_KEY e LI_APPLICATION_KEY estiverem preenchidas, o app cria/atualiza
# esta loja sozinho no boot. É só colar as chaves e subir.
STORE_ID=principal
STORE_NAME=Minha Loja
# Chaves da Loja Integrada (mesmas usadas no npm run test:li)
LI_API_KEY=
LI_APPLICATION_KEY=
# Mensagem de recuperação (opcional). Variáveis: {{nome}} {{produto}} {{valor}} {{loja}}
# STORE_MESSAGE_TEMPLATE=

# ───────── Evolution API (WhatsApp) ─────────
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
